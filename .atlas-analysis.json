  "keyFeatures": [
    "Real-time messaging with Socket.io and Redis adapter",
    "AI-powered translation using Groq API",
    "AI conversation summarization",
    "Smart reply suggestions",
    "File uploads (images, voice notes) via MinIO/S3",
    "Channels and workspaces for team collaboration",
    "Direct messaging between users",
    "Friend request system",
    "Horizontal scaling with Kubernetes",
    "PostgreSQL database with Prisma ORM"
  ],
  "publicApiSurface": [
    "POST /api/register - User registration",
    "POST /api/login - User authentication",
    "GET /api/channels - List channels",
    "POST /api/channels - Create channel",
    "GET /api/channels/:id - Get channel details",
    "POST /api/channels/join - Join channel by invite code",
    "GET /api/friends - List friends",
    "POST /api/friends/request - Send friend request",
    "POST /api/friends/accept - Accept friend request",
    "GET /api/users/:id - Get user profile",
    "PUT /api/users/:id - Update user profile",
    "POST /api/upload - Upload file",
    "POST /api/ai/summarize - Summarize conversation",
    "POST /api/ai/translate - Translate message",
    "POST /api/ai/suggest-replies - Get smart reply suggestions",
    "Socket: join_channel - Join a channel or DM room",
    "Socket: send_message - Send a message",
    "Socket: receive_message - Receive a message",
    "Socket: load_history - Load message history"
  ]
}
